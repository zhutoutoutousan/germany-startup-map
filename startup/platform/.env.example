# Copy to .env.local and fill in (do not commit .env.local).
#
# Option A — explicit Prisma vars (Supabase → Settings → Database):
#   DATABASE_URL = pooled URI (PgBouncer, often :6543)
#   DIRECT_URL   = direct db.[ref].supabase.co :5432
#
# Option B — Vercel/Supabase integration style (no DATABASE_URL needed):
#   POSTGRES_PRISMA_URL, POSTGRES_HOST, POSTGRES_PASSWORD, POSTGRES_USER, POSTGRES_DATABASE
#   The app maps these to DATABASE_URL + DIRECT_URL automatically.

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Existing app vars
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
